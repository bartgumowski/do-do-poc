{
  "cleanUrls": true,
  "trailingSlash": false,
  "framework": null,
  "buildCommand": "",
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/invite/:token", "destination": "/index.html" },
    { "source": "/pay/:intent", "destination": "/api/expense-pay?intent=:intent" }
  ],
  "crons": [
    {
      "path": "/api/remind",
      "schedule": "*/15 * * * *"
    }
  ]
}
